{
  "name": "@webcli-dom/companion",
  "version": "0.1.0",
  "description": "Single-process local companion with JSON API and Ink TUI for webcli-dom",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "webcli-companion": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx src/cli.ts start",
    "status": "tsx src/cli.ts status",
    "stop": "tsx src/cli.ts stop",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.12",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@webcli-dom/core": "workspace:*",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "ws": "^8.19.0"
  }
}
