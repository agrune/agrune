{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@agrune/core": ["packages/core/src/index.ts"],
      "@agrune/runtime": ["packages/runtime/src/index.ts"],
      "@agrune/runtime/page-runtime": ["packages/runtime/src/page-runtime.ts"],
      "@agrune/browser": ["packages/browser/src/index.ts"],
      "@agrune/devtools": ["packages/devtools/src/index.ts"],
      "@agrune/extension": ["packages/extension/src/content/index.ts"],
      "@agrune/mcp": ["packages/mcp/src/index.ts"]
    }
  }
}
